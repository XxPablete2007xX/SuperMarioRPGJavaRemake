<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="720.0" maxWidth="1290.0" minHeight="720.0" minWidth="1290.0" prefHeight="720.0" prefWidth="1290.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.supermariorpgjava.remake.HallOfFameController">
   <children>
      <!-- BACKGROUND: Extraído de "Ending (Thank You)" -->
      <ImageView fx:id="imgFondo" fitHeight="720.0" fitWidth="1290.0" pickOnBounds="true" />

      <AnchorPane prefHeight="720.0" prefWidth="1290.0">
         <children>
            <!-- TÍTULO: Estilo Font.png -->
            <Label layoutX="436.0" layoutY="45.0" text="HALL OF FAME" textFill="#f8d000">
               <font>
                  <Font name="Monospaced Bold" size="64.0" />
               </font>
               <style>-fx-effect: dropshadow(one-pass-box, black, 4, 0, 4, 4);</style>
            </Label>

            <!-- CONTENEDOR DE LA TABLA: Estilo ventana azul de "Menus" -->
            <VBox layoutX="145.0" layoutY="140.0" prefHeight="450.0" prefWidth="1000.0" style="-fx-background-color: #000000, #ffffff, linear-gradient(to bottom, #082184 0%, #000042 100%); -fx-background-insets: 0, 2, 4; -fx-background-radius: 0; -fx-padding: 15;">
               <children>
                  <TableView fx:id="tableHallOfFame" prefHeight="420.0" prefWidth="970.0" style="-fx-background-color: transparent; -fx-base: #082184; -fx-control-inner-background: transparent;">
                    <columns>
                      <TableColumn fx:id="colNombre" prefWidth="245.59990233182907" text="JUGADOR" />
                      <TableColumn fx:id="colTiempo" prefWidth="204.80003356933594" text="TIEMPO" />
                      <TableColumn fx:id="colFecha" prefWidth="226.39996337890625" text="FECHA" />
                      <TableColumn fx:id="colMonedas" prefWidth="147.199951171875" text="MONEDAS" />
                        <TableColumn fx:id="colMonedasRana" prefWidth="148.800048828125" text="MONEDAS RANA" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            
            <!-- DECORACIÓN: Sprites de Mario y Peach de "Playable Characters" -->
            <ImageView fx:id="imgDecor1" fitHeight="100.0" fitWidth="100.0" layoutX="50.0" layoutY="50.0" />
            <ImageView fx:id="imgDecor2" fitHeight="100.0" fitWidth="100.0" layoutX="1140.0" layoutY="50.0" />
            <Button fx:id="btnVolver" layoutX="575.0" layoutY="627.0" mnemonicParsing="false" onAction="#volver" onMouseEntered="#aparecerFlecha" onMouseExited="#desaparecerFlecha" style="-fx-background-color: #000000, #ffffff, linear-gradient(to bottom, #082184 0%, #000042 100%); -fx-background-insets: 0, 2, 4; -fx-background-radius: 0; -fx-text-fill: white; -fx-font-family: Consolas; -fx-font-weight: bold; -fx-font-size: 24; -fx-padding: 10 30 10 30;" text="VOLVER" />
            <ImageView fx:id="imgFlecha" fitHeight="65.0" fitWidth="65.0" layoutX="490.0" layoutY="619.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </AnchorPane>
   </children>
</StackPane>
