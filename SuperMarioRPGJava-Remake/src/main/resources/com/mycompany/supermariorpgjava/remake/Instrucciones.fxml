<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<StackPane maxHeight="720.0" maxWidth="1290.0" minHeight="720.0" minWidth="1290.0" prefHeight="720.0" prefWidth="1290.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.supermariorpgjava.remake.InstruccionesController">
   <children>
      <!-- FONDO: La casa de Mario (Mario's Pad) [2] -->
      <ImageView fx:id="imgFondo" fitHeight="720.0" fitWidth="1290.0" pickOnBounds="true">
         <image>
            <Image url="@../../../../img/fondoInstrucciones.png" />
         </image>
      </ImageView>

      <!-- FILTRO DE OSCURECIMIENTO -->
      <Rectangle fill="#000000b3" height="720.0" width="1290.0" />

      <AnchorPane prefHeight="720.0" prefWidth="1290.0">
         <children>
            <!-- CAJA DE TEXTO PRINCIPAL: Estilo Ventana Azul [1] -->
            <VBox layoutX="195.0" layoutY="85.0" prefHeight="550.0" prefWidth="900.0" style="-fx-background-color: #000000, #ffffff, linear-gradient(to bottom, #082184 0%, #000042 100%); -fx-background-insets: 0, 2, 4; -fx-background-radius: 0;">
               <children>
                  
                  <!-- CABECERA DE SECCIÓN -->
                  <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="900.0" style="-fx-padding: 0 30 0 30;">
                     <children>
                        <Label fx:id="seccion" textFill="#f8d000">
                           <font><Font name="Monospaced Bold" size="32.0" /></font>
                           <style>-fx-effect: dropshadow(one-pass-box, black, 2, 0, 2, 2);</style>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="pagina" textFill="WHITE">
                           <font><Font name="Monospaced Bold" size="20.0" /></font>
                        </Label>
                     </children>
                  </HBox>
                  
                  
                  <WebView fx:id="cuerpoInfo" prefHeight="390.0" prefWidth="142.0" />

                  <!-- NAVEGACIÓN [1] -->
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="900.0" spacing="100.0">
                     <children>
                        <Button fx:id="btnAnterior" mnemonicParsing="false" onAction="#volverPagina" prefWidth="180.0" style="-fx-background-color: #000000, #ffffff, #082184; -fx-background-insets: 0, 1, 2; -fx-background-radius: 0;" text="ANTERIOR" textFill="WHITE">
                           <font><Font name="Monospaced Bold" size="18.0" /></font>
                        </Button>
                        <Button fx:id="btnSiguiente" mnemonicParsing="false" onAction="#pasarPagina" prefWidth="180.0" style="-fx-background-color: #000000, #ffffff, #082184; -fx-background-insets: 0, 1, 2; -fx-background-radius: 0;" text="SIGUIENTE" textFill="WHITE">
                           <font><Font name="Monospaced Bold" size="18.0" /></font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="btnVolver" layoutX="1133.0" layoutY="670.0" mnemonicParsing="false" onAction="#volver" onMouseEntered="#aparecerFlecha" onMouseExited="#desaparecerFlecha" prefHeight="36.0" prefWidth="126.0" style="-fx-background-color: #000000, #ffffff, #082184; -fx-background-insets: 0, 1, 2; -fx-background-radius: 0;" text="VOLVER" textFill="WHITE">
               <font>
                  <Font name="Monospaced Bold" size="18.0" />
               </font>
            </Button>
            <ImageView fx:id="imgFlecha" fitHeight="50.0" fitWidth="50.0" layoutX="1063.0" layoutY="663.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </AnchorPane>
   </children>
</StackPane>
