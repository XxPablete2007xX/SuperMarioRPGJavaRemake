<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.web.WebView?>

<StackPane maxHeight="720.0" maxWidth="1290.0" minHeight="720.0" minWidth="1290.0" prefHeight="720.0" prefWidth="1290.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.supermariorpgjava.remake.CreditosController">
   <children>
      <!-- FONDO: Star Hill o Star Road para un toque nostálgico -->
      <ImageView fx:id="imgFondo" fitHeight="720.0" fitWidth="1290.0" pickOnBounds="true" />

      <!-- FILTRO OSCURO -->
      <Region prefHeight="720.0" prefWidth="1290.0" style="-fx-background-color: rgba(0,0,0,0.5);" />

      <AnchorPane prefHeight="720.0" prefWidth="1290.0">
         <children>
            <!-- CONTENEDOR PRINCIPAL: Estilo Ventana Azul de Menus -->
            <VBox layoutX="145.0" layoutY="60.0" prefHeight="550.0" prefWidth="1000.0" style="-fx-background-color: #000000, #ffffff, linear-gradient(to bottom, #082184 0%, #000042 100%); -fx-background-insets: 0, 2, 4; -fx-background-radius: 0;">
               <children>
                  
                  <!-- TÍTULO DE CRÉDITOS -->
                  <AnchorPane prefHeight="80.0" prefWidth="1000.0">
                     <children>
                        <Label layoutX="350.0" layoutY="20.0" text="CRÉDITOS &amp; COPYRIGHT" textFill="#f8d000">
                           <font>
                              <Font name="Monospaced Bold" size="28.0" />
                           </font>
                           <style>-fx-effect: dropshadow(one-pass-box, black, 2, 0, 2, 2);</style>
                        </Label>
                     </children>
                  </AnchorPane>

                  <!-- WEBVIEW: Para cargar el HTML de créditos -->
                  <StackPane prefHeight="450.0" prefWidth="1000.0" style="-fx-padding: 0 20 20 20;">
                     <children>
                        <WebView fx:id="webCredits" prefHeight="400.0" prefWidth="960.0" />
                     </children>
                  </StackPane>
               </children>
            </VBox>

            <!-- BOTÓN VOLVER: Estilo manual -->
            <Button fx:id="btnVolver" layoutX="585.0" layoutY="640.0" mnemonicParsing="false" onAction="#volver" onMouseEntered="#aparecerFlecha" onMouseExited="#desaparecerFlecha" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #000000, #ffffff, #082184; -fx-background-insets: 0, 1, 2; -fx-background-radius: 0;" text="VOLVER" textFill="WHITE">
               <font><Font name="Monospaced Bold" size="16.0" /></font>
            </Button>
            <ImageView fx:id="imgFlecha" fitHeight="60.0" fitWidth="60.0" layoutX="502.0" layoutY="633.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </AnchorPane>
   </children>
</StackPane>
